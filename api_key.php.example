<?php
// API key and security configuration
// Copy this file to api_key.php and customize it:
//   cp api_key.php.example api_key.php

$apiKey = 'your-secure-secret';

// Require HTTPS for all API requests (recommended for public instances)
$requireHttps = true;

// Allowed target domains for macro URLs (SSRF protection)
// Empty array = no domain whitelist, but private/localhost hosts remain blocked
// Example: ['httpbin.org', 'api.example.com']
$allowedDomains = ['httpbin.org'];

// Rate limit per IP per minute (0 = disabled)
$rateLimitPerMinute = 60;